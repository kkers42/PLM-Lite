# PLM Lite V1.0 — Environment Variables
# Copy to .env and fill in your values

# ── Auth mode ───────────────────────────────────────────────────────────────
# "windows" → No password — whoever is logged into Windows IS the PLM user.
#             Admin creates accounts using the Windows username (e.g. DOMAIN\Suzie or just Suzie).
#             Best choice for company networks / engineering workstations.
# "local"   → Manual username + password login. Good for mixed or non-Windows environments.
# "google"  → Google OAuth. For cloud/VPS deployments.
AUTH_MODE=windows

# JWT secret key — generate with: openssl rand -hex 32
SECRET_KEY=change-me-to-a-long-random-string

# ── Google OAuth (only needed when AUTH_MODE=google) ────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APP_BASE_URL=https://3dprintdudes.io/plm

# Optional: comma-separated email whitelist. Empty = allow any Google account.
# ALLOWED_EMAILS=you@example.com,teammate@example.com

# ── Storage paths ────────────────────────────────────────────────────────────
# Windows exe: paths relative to the folder the exe lives in (or absolute).
# Docker:      set to /srv/plm/files and /srv/plm/plm.db (mapped volumes).
FILES_ROOT=./data/files
DB_PATH=./data/plm.db

# ── Setup backdoor ───────────────────────────────────────────────────────────
# Emergency admin page at /setup?pw=YOUR_PASSWORD — lets you fix user roles.
# Change this to something secret.
ADMIN_PASSWORD=plmadmin

# ── File versioning ──────────────────────────────────────────────────────────
MAX_FILE_VERSIONS=3

# CAD file extensions that get versioned (comma-separated, with dot)
CAD_EXTENSIONS=.prt,.asm,.drw,.stl,.3mf,.obj,.step,.stp,.sldprt,.sldasm,.ipt,.iam

# ── Open-in-place (Windows LAN only) ─────────────────────────────────────────
# UNC path to the same directory that FILES_ROOT points to inside Docker.
# Windows clients need read access to this share to open files directly.
# Example: FILES_ROOT=/srv/plm/files → FILES_UNC_ROOT=\\192.168.1.37\plm-files
# Leave blank to disable the "Open" button (download-only mode).
# FILES_UNC_ROOT=\\192.168.1.37\plm-files

# If workstations map the share to a drive letter, set it here (e.g. Z:)
# Drive letters are more reliable than UNC paths with some NX installations.
# FILES_MAPPED_DRIVE=Z:
